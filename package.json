{
  "name": "sourceport",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "sources/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts --passWithNoTests"
  },
  "devDependencies": {
    "@jackwener/opencli": "1.8.6",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
